rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regras simplificadas e robustas
    match /users/{userId} {
      // Qualquer pessoa autenticada pode ler os perfis (para verificar roles no dashboard)
      allow read: if request.auth != null;

      // Permitir criar o próprio perfil
      allow create: if request.auth != null && request.auth.uid == userId;

      // Permitir atualizar o próprio perfil (protegendo o campo 'funcao')
      allow update: if request.auth != null && request.auth.uid == userId
                    && (request.resource.data.funcao == resource.data.funcao || !('funcao' in resource.data));

      // Admin tem acesso total (baseado no campo 'funcao' do documento do admin)
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Admin';
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Admin';
    }
  }
}
