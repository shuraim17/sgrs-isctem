rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow any authenticated user to read the user list
      allow read: if request.auth != null;

      // Allow users to create their own profile
      allow create: if request.auth != null && request.auth.uid == userId;

      // Allow users to update their own profile, but NOT their role (funcao)
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.funcao == resource.data.funcao;

      // Allow Admins to manage all users and roles
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao.lower() == 'admin';
    }
  }
}
