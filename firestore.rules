rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função para verificar se o utilizador logado é Admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.funcao == 'Admin';
    }

    match /users/{userId} {
      // PERMISSÃO PÚBLICA DE LEITURA: Necessária para encontrar o telemóvel por email
      // antes de o utilizador estar autenticado (na recuperação de senha).
      allow read: if true;
      
      // Criação: Permitir que o utilizador crie o seu próprio perfil inicial
      allow create: if request.auth != null && request.auth.uid == userId;

      // Atualização: Permitir que o utilizador atualize o seu perfil, mas bloqueia mudança de função
      allow update: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.funcao == resource.data.funcao;
      
      // Admin: Pode gerir todos os utilizadores
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
